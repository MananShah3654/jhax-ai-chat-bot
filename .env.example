PORT=3000

# Leave empty to run the demo with in-memory seeded data.
# Use this when Postgres is running:
# DATABASE_URL=postgres://ai_app:ai_demo_password@localhost:5432/olympic_ai_demo
DATABASE_URL=

# Any OpenAI-compatible chat-completions endpoint works.
# Without an API key, the demo uses a deterministic local responder.
#
# ═══ FREE OPTIONS (no credit card) ════════════════════════════════════════
#
# ── Option A: Groq (fastest, generous free tier) ──────────────────────────
# Sign up at https://console.groq.com — instant key, no card.
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# Other Groq models: llama-3.1-8b-instant, mixtral-8x7b-32768
#
# ── Option B: OpenRouter free-tier models ─────────────────────────────────
# Sign up at https://openrouter.ai/keys, then browse models with
# `:free` suffix at https://openrouter.ai/models?max_price=0
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# ── Option C: Google Gemini free tier ─────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey — no card required.
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.0-flash
#
# ── Option D: Ollama (run any open model locally, fully free) ─────────────
# Install from https://ollama.com, then `ollama pull llama3.1`
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1
#
# ═══ PAID OPTIONS ══════════════════════════════════════════════════════════
#
# ── OpenRouter (paid models — one key for Claude/GPT/Gemini/etc.) ─────────
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=anthropic/claude-haiku-4-5
#
# ── OpenAI direct ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Only this origin can call the API from a browser in production.
CORS_ORIGIN=http://localhost:3000
